<%-include('layouts/header') -%>
<%-include('layouts/nav') -%>

  
  <section class="w50">
    <!--form name="myform" method="Post" onsubmit="return formSubmit();"  action="" -->
    <form name="myform" method="Post" action="/process" enctype="multipart/form-data">
      <label>Name</label>
      <input id="name" placeholder="First Last" type="text" name="name"><br/>

      <label>Email</label>
      <input id="email" placeholder="email@domain.com" type="email" name="email"><br/>

      <label>Phone</label>
      <input id="phone" placeholder="123-123-1234" type="phone" name="phone"><br/>

      <label>Post Code</label>
      <input id="postcode" placeholder="X9X 9X9" type="postcode" name="postcode"><br/>
      
      <label>Will you have lunch?</label>
      <input type="radio" value="yes" id="radio1" name="lunch">Yes
      &nbsp;&nbsp;&nbsp;&nbsp;
      <input type="radio" value="no" id="radio2" name="lunch">No
      <br/>

      <label>Number of Tickets</label>
      <!--select name="tickets" id="tickets">
          <option value="">----- Select -----</option>
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
      </select><br/-->

      <input id="tickets" placeholder="Number of Tickets" type="text" name="tickets"><br/>

      
      <label>Which Campus?</label>
      <select name="campus" id="campus">
          <option value="">----- Select -----</option>
          <option value="Doon">Doon</option>
          <option value="Waterloo">Waterloo</option>
          <option value="Cambridge">Cambridge</option>
      </select>

      <label>Add Image: </label>
      <input type="file" name="myImage" id="myImage" accept="image/*"/>


      <br/><br/>

      <input type="submit" value="Submit">
      <p id="errors">

        <% if(typeof errorInfo != 'undefined'){
          for(var err of errorInfo ){%>
            <h3>  <%=err.msg%>   </h3>
          <%}
        } %>



      </p>
    </form>  
</section>
<section class="w50">
  <div class="formData">
    <p id="formResult">This is where the form data will show up.</p>
    
    <%if(typeof receipt != 'undefined'){%>
      <p>Name: <%=receipt.name%></p>
      <p>Lunch: $ <%=receipt.lunchCost%></p>
      <p>Ticket: $ <%=receipt.ticketCost%></p>
      <p>Sub Total: $ <%=receipt.subTotal%></p>
      <p>Taxes: <%=receipt.taxes.toFixed(2)%></p>
      <p>Total: <%=receipt.total.toFixed(2)%></p>
      <img src="<%=receipt.image%>" width=300px/>
    <%}%>


  </div>
</section>
<div class="clear"></div>

<%-include('layouts/footer') -%>





